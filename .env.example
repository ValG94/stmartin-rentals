NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin login (Supabase Auth user used in the admin dashboard)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# PayPal
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id

# Fygaro (paiement CB Caraïbes — Chenille Investments Ltd)
# Récupérées depuis Fygaro → Settings → API Credentials
FYGARO_PUBLIC_KEY=your-fygaro-public-key
FYGARO_SECRET_KEY=your-fygaro-secret-key
# Webhook secret — OPTIONNEL. Fygaro signe les webhooks avec la SECRET_KEY
# du compte (Settings → API Credentials). Ne définir cette variable QUE si
# tu veux forcer une clé différente (rotation, tests, etc.). Sinon le code
# fallback automatiquement sur FYGARO_SECRET_KEY ci-dessus.
# FYGARO_WEBHOOK_SECRET=your-fygaro-webhook-secret
# URLs des Payment Buttons créés dans Fygaro Links.
# Le montant statique (0.01 par défaut) est overridé dynamiquement via
# JWT signé côté serveur.
FYGARO_PAYMENT_URL_BOOKING=https://www.fygaro.com/en/pb/[uuid-booking]/
FYGARO_PAYMENT_URL_DEPOSIT=https://www.fygaro.com/en/pb/[uuid-caution]/
# Feature flag côté client — expose l'option 'Carte bancaire' dans le
# BookingForm. Tant qu'à 'false' (ou absent), l'option apparaît en
# 'Bientôt disponible'. Passer à 'true' quand le compte Fygaro sera
# sur un plan avec Manual Capture + JWT signing (upgrade Free Trial).
NEXT_PUBLIC_FYGARO_ENABLED=false

# MODE TEST — override du montant envoyé à Fygaro (utile pour tester
# le flow end-to-end sans payer $4000+). Ex : "1" → tout paiement
# Fygaro sera de $1. Le webhook skip la vérif de montant en test mode.
# À RETIRER une fois les tests validés pour repasser en prod réelle.
# FYGARO_TEST_AMOUNT=1

# Emails (Resend) — https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
# EMAIL_FROM must be either a verified domain on Resend, or use the
# default "onboarding@resend.dev" until a domain is verified.
EMAIL_FROM=Island Living SXM <onboarding@resend.dev>
# Where the owner receives booking notifications
ADMIN_EMAIL=contact@islandlivingsxm.com

# Site
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app
